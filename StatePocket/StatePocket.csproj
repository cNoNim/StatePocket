<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <AssemblyName>statepocket</AssemblyName>
        <AssemblyTitle>State Pocket</AssemblyTitle>
        <Product>State Pocket</Product>
        <RootNamespace>StatePocket</RootNamespace>
        <UseAppHost>true</UseAppHost>
        <IsPackable>true</IsPackable>
        <PackAsTool>true</PackAsTool>
        <RuntimeIdentifiers>osx-x64;osx-arm64;linux-x64;linux-arm64;win-x64;win-arm64</RuntimeIdentifiers>
        <ToolPackageRuntimeIdentifiers>osx-x64;osx-arm64;linux-x64;linux-arm64;win-x64;win-arm64</ToolPackageRuntimeIdentifiers>
        <PublishTrimmed>true</PublishTrimmed>
        <PackageId>StatePocket</PackageId>
        <ToolCommandName>statepocket</ToolCommandName>
        <ResourceUriScheme>statepocket</ResourceUriScheme>
        <Title>State Pocket</Title>
        <Description>Persistent local JSON state for agents and tools, exposed through MCP and backed by SQLite.</Description>
        <PackageTags>mcp;model-context-protocol;agent;sqlite;json;kv-store;tool</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <None Include="..\README.md" Pack="true" PackagePath="\" Link="README.md" />
        <EmbeddedResource Include="..\Docs\**\*.md" LogicalName="Docs/%(RecursiveDir)%(Filename)%(Extension)" />
        <AssemblyMetadata Include="PackageId" Value="$(PackageId)" />
        <AssemblyMetadata Include="PackageProjectUrl" Value="$(PackageProjectUrl)" />
        <AssemblyMetadata Include="ToolCommandName" Value="$(ToolCommandName)" />
        <AssemblyMetadata Include="ResourceUriScheme" Value="$(ResourceUriScheme)" />
        <ProjectReference Include="..\StatePocket.Json.Path\StatePocket.Json.Path.csproj" />
        <ProjectReference Include="..\StatePocket.Json.Patch\StatePocket.Json.Patch.csproj" />
        <ProjectReference Include="..\StatePocket.Json.Pointer\StatePocket.Json.Pointer.csproj" />
        <PackageReference Include="Meziantou.Analyzer" PrivateAssets="all">
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <PackageReference Include="DotNext.Threading"/>
        <PackageReference Include="Microsoft.Data.Sqlite"/>
        <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables"/>
        <PackageReference Include="Microsoft.Extensions.Hosting"/>
        <PackageReference Include="Microsoft.Extensions.Logging.Console"/>
        <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions"/>
        <PackageReference Include="Microsoft.VisualStudio.Threading.Analyzers" PrivateAssets="all">
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <PackageReference Include="ModelContextProtocol"/>
        <PackageReference Include="Serilog"/>
        <PackageReference Include="Serilog.Extensions.Logging"/>
        <PackageReference Include="Serilog.Formatting.Compact"/>
        <PackageReference Include="Serilog.Sinks.File"/>
        <PackageReference Include="System.CommandLine"/>
        <PackageReference Include="Tomlyn"/>
    </ItemGroup>
</Project>
